# Copy to web/.env.local or symlink repo-root .env here.
# When running `npm run dev` from web/, use paths relative to web/ (e.g. ../f94client.json).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

GOOGLE_REFRESH_TOKEN=
# Absolute path recommended when cwd is web/
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=

# Optional: require Authorization: Bearer <secret> or x-review-secret header on /api/content-review/* and /content/review
REVIEW_DASHBOARD_SECRET=

# Stored on PATCH when status changes (approved / rejected / needs_rewrite)
REVIEWED_BY=
