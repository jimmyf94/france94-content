# Copy to web/.env.local or symlink repo-root .env here.
# When running `npm run dev` from web/, use paths relative to web/ (e.g. ../f94client.json).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Publishing prep: plain OAuth token only (EAA…), not App Secret / not JSON. IG User id numeric.
# Tokens expire (Graph 190/463). Refresh INSTAGRAM_GRAPH_ACCESS_TOKEN; long-lived exchange or System User for automation.
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# INSTAGRAM_GRAPH_API_VERSION=v21.0
# Troubleshooting: from repo root run `npm run check:instagram-token` (loads .env + web/.env.local).
# META_APP_ID + META_APP_SECRET: debug_token (check:instagram-token) and meta:system-user:* CLI.
# System User: META_SYSTEM_USER_ID, META_BUSINESS_BOOTSTRAP_ACCESS_TOKEN — see repo root .env.example + Meta doc:
# https://developers.facebook.com/docs/marketing-api/system-users/install-apps-and-generate-tokens/

PUBLIC_MEDIA_BUCKET_NAME=
PUBLIC_MEDIA_BASE_URL=

GOOGLE_REFRESH_TOKEN=
# Absolute path recommended when cwd is web/
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=

# Optional: require Authorization: Bearer <secret> or x-review-secret header on /api/content-review/* and /content/review
REVIEW_DASHBOARD_SECRET=

# Stored on PATCH when status changes (approved / rejected / needs_rewrite)
REVIEWED_BY=

# Gemini (candidate regeneration API). Repo-root .env is merged by next.config when present.
GEMINI_API_KEY=
# Optional per-route overrides — see root .env.example (FR94_MODEL_*). Routed calls ignore GEMINI_MODEL.
GEMINI_MODEL=

FR94_PROMPT_VERSION=2026-05-10-v1
# Paid tier usually required (free tier cache storage limit is often 0).
GEMINI_ENABLE_EXPLICIT_CACHING=false
GEMINI_CACHE_TTL_SECONDS=86400
GEMINI_CACHE_DEBUG=false
# Explicit cache: stable prompt must be large enough (~1024 tokens); see root .env.example
GEMINI_CACHE_MIN_STABLE_CHARS=3600
LLM_LOGGING_DISABLE=

# LLM settings UI (/content/review/settings): apply repo supabase/migrations/*_llm_route_settings.sql
# in Supabase (llm_route_settings table + fr94_llm_usage_daily RPC on llm_call_logs).
# Stable prompts from settings: supabase/migrations/*_llm_stable_prompts.sql (llm_stable_prompts).
# Usage chart breakdown (hover: tokens per model, actions per route): *_llm_usage_breakdown.sql.

# Optional: regenerate prompt override (default: ../scripts/prompts/france94-post-candidate-rewrite.txt from repo root)
POST_CANDIDATE_REWRITE_PROMPT_PATH=
