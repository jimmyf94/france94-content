{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@fr94/ai/*": ["../scripts/lib/ai/*"],
      "@fr94/publishing/*": ["../scripts/lib/publishing/*"],
      "@fr94/asset-usage": ["../scripts/lib/asset-usage"],
      "@fr94/content-ledger": ["../scripts/lib/content-ledger"],
      "@fr94/candidate-collision": ["../scripts/lib/candidate-collision-check"],
      "@fr94/review-folder-thumbnail": ["../scripts/lib/review-folder-thumbnail"],
      "@fr94/drive-media-download": ["../scripts/lib/drive-media-download"],
      "@fr94/drive-video-poster": ["../scripts/lib/drive-video-poster"],
      "@fr94/video-preprocess": ["../scripts/lib/video-preprocess"],
      "@fr94/content-series": ["../scripts/lib/content-series"],
      "@fr94/reel-assembly": ["../scripts/lib/reel-assembly"],
      "@fr94/reel-clip-limits": ["../scripts/lib/reel-clip-limits"],
      "@fr94/reel-hook-lab": ["../scripts/lib/reel-hook-lab"],
      "@fr94/reel-text-style": ["../scripts/lib/reel-text-style"],
      "@fr94/reel-render-progress": ["../scripts/lib/reel-render-progress"],
      "@fr94/reel-render-defaults": ["../scripts/lib/reel-render-defaults"],
      "@fr94/content-clips": ["../scripts/lib/content-clips"],
      "@fr94/pipeline-settings": ["../scripts/lib/pipeline-settings"],
      "@fr94/publishing/instagram-graph": ["../scripts/lib/publishing/instagram-graph"],
      "@fr94/planner-asset-ranking": ["../scripts/lib/planner-asset-ranking"],
      "@fr94/post-candidate-shared": ["../scripts/lib/post-candidate-shared"],
      "@fr94/filename-sanitize": ["../scripts/lib/filename-sanitize"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
