# Google OAuth client JSON from GCP (APIs & Services → Credentials).
# Supports either "Web application" ({ "web": ... }) or "Desktop app" ({ "installed": ... }) download JSON.
# Authorized redirect URI must include: http://127.0.0.1:3333/oauth2callback
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=

# npm run oauth:google-drive — requests https://www.googleapis.com/auth/drive (rename/move needs this).
# Refresh tokens do NOT pick up new scopes: revoke old access (Google Account → Security → Third-party access),
# run oauth again, replace GOOGLE_REFRESH_TOKEN. Debug: npm run check:drive-token
GOOGLE_REFRESH_TOKEN=

# Raw inbox folder to scan (must be visible to the signed-in Google account)
GOOGLE_DRIVE_FOLDER_ID=

# Target folder for processed raw assets (rename + move worker)
GOOGLE_DRIVE_PROCESSED_RAW_FOLDER_ID=

# Parent folder for per–post-candidate review folders (copies only; originals stay in processed raw)
GOOGLE_DRIVE_READY_FOR_REVIEW_FOLDER_ID=

# Daily post candidate planner: recently processed assets window, LLM batch size, target concepts per run
POST_CANDIDATE_BATCH_DAYS=14
POST_CANDIDATE_MAX_ASSETS=80
POST_CANDIDATE_DAILY_TARGET=5
# Optional: audio transcription prompt for sampled video (default: scripts/prompts/france94-audio-transcription.txt)
AUDIO_TRANSCRIPTION_PROMPT_PATH=

# Optional: post candidate planner prompt (default: scripts/prompts/france94-post-candidates.txt)
POST_CANDIDATE_PROMPT_PATH=



SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Post review dashboard (web/ Next app — copy these into web/.env.local or symlink .env)
# REVIEW_DASHBOARD_SECRET=
# REVIEWED_BY=

# Optional: override path to the media-analysis prompt (default: scripts/prompts/france94-media-analysis.txt)
CONTENT_ANALYSIS_PROMPT_PATH=

# Optional: audio transcription prompt for sampled video (default: scripts/prompts/france94-audio-transcription.txt)
AUDIO_TRANSCRIPTION_PROMPT_PATH=

# Optional: post candidate planner prompt (default: scripts/prompts/france94-post-candidates.txt)
POST_CANDIDATE_PROMPT_PATH=

# Gemini Developer API (analysis worker). Vertex AI is not used here — files.upload is API-key only.
GEMINI_API_KEY=

# Optional; default gemini-2.5-flash
GEMINI_MODEL=

# Analysis worker batching / safety (defaults: 5 and 500)
CONTENT_ANALYSIS_BATCH_SIZE=
MAX_ANALYSIS_FILE_SIZE_MB=

# Rename/move worker (defaults: 10)
CONTENT_RENAME_BATCH_SIZE=

# Video preprocessing (analysis worker)
# VIDEO_ANALYSIS_MODE: sampled (default) or frames_only (skip audio entirely)
VIDEO_ANALYSIS_MODE=sampled
VIDEO_FRAME_MAX_WIDTH=768
VIDEO_MAX_SAMPLE_FRAMES=12
VIDEO_FULL_ANALYSIS_MAX_SECONDS=30

# Reverse geocoding (Nominatim). User-Agent must identify the app + a contact per Nominatim ToS.
NOMINATIM_USER_AGENT=france94-content-manager/0.1 (contact: you@example.com)
# Optional self-hosted Nominatim base URL (defaults to https://nominatim.openstreetmap.org)
NOMINATIM_BASE_URL=
# Optional Accept-Language for response labels (default: fr,en)
NOMINATIM_ACCEPT_LANGUAGE=
GEOCODE_BATCH_SIZE=25
NOMINATIM_MIN_INTERVAL_MS=1100
