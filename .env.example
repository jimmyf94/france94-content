# France94 Content Manager — single env file at repo root.
# Copy to `.env` for local dev. Vercel (root dir = web/) and GitHub Actions use the same keys as project/repo secrets.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Web app auth (Google OAuth via Supabase; same project URL, anon/publishable key from dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated emails allowed to sign in (e.g. you@france94.fr)
ALLOWED_EMAILS=

# --- Google Drive OAuth ---
# Local: path to GCP OAuth client JSON (Web or Desktop download).
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=
# Cloud (Vercel / GHA): inline JSON (same shape as f94client.json). Overrides file path when set.
# GOOGLE_OAUTH_CLIENT_SECRETS_JSON={"installed":{"client_id":"...","client_secret":"..."}}

# npm run oauth:google-drive — requests https://www.googleapis.com/auth/drive (rename/move needs this).
# Refresh tokens do NOT pick up new scopes: revoke old access, run oauth again, replace GOOGLE_REFRESH_TOKEN.
GOOGLE_REFRESH_TOKEN=

# Raw inbox folder to scan (must be visible to the signed-in Google account)
GOOGLE_DRIVE_FOLDER_ID=

# Target folder for processed raw assets (rename + move worker)
GOOGLE_DRIVE_PROCESSED_RAW_FOLDER_ID=

# Parent folder for per–post-candidate review folders (copies only; originals stay in processed raw)
GOOGLE_DRIVE_READY_FOR_REVIEW_FOLDER_ID=

# --- Gemini ---
GEMINI_API_KEY=

# Per-operation overrides (optional). Defaults: scripts/lib/ai/model-routes.ts
# FR94_MODEL_ASSET_ANALYSIS_IMAGE=
# FR94_MODEL_ASSET_ANALYSIS_VIDEO_SAMPLED=
# FR94_MODEL_CANDIDATE_GENERATION=
# FR94_MODEL_CANDIDATE_REGENERATION=
GEMINI_MODEL=

# HTTP timeout for Gemini API calls (ms). Full-video analysis can be slow to return headers; default 600000 (10 min).
# FR94_GEMINI_HTTP_TIMEOUT_MS=900000

FR94_PROMPT_VERSION=2026-05-23-v1
# Explicit Gemini cache for stable prompts (voice/mission/series). Set false to disable.
GEMINI_ENABLE_EXPLICIT_CACHING=true
GEMINI_CACHE_TTL_SECONDS=86400
GEMINI_CACHE_DEBUG=false
GEMINI_CACHE_MIN_STABLE_CHARS=3600
LLM_LOGGING_DISABLE=

# --- Post candidate planner ---
POST_CANDIDATE_BATCH_DAYS=14
POST_CANDIDATE_MAX_ASSETS=80
# Max assets sent to the LLM after deterministic pre-ranking (default 15)
POST_CANDIDATE_PLANNER_MAX_ASSETS=15
# Candidates requested per LLM call (1–5, default 4)
POST_CANDIDATE_LLM_TARGET=4
# Top (asset, series) pairs for per-pair generation (clamped 2–4)
POST_CANDIDATE_TOP_PAIRS=3
# Max assets in carousel/story bundles (clamped in code)
POST_CANDIDATE_CAROUSEL_MAX_ASSETS=6
POST_CANDIDATE_STORY_MAX_ASSETS=5
# Legacy alias when POST_CANDIDATE_LLM_TARGET is unset
POST_CANDIDATE_DAILY_TARGET=4
# Optional prompt paths (defaults under scripts/prompts/)
# AUDIO_TRANSCRIPTION_PROMPT_PATH=
# POST_CANDIDATE_PROMPT_PATH=
# POST_CANDIDATE_REWRITE_PROMPT_PATH=
# CONTENT_ANALYSIS_PROMPT_PATH=

# --- Content analysis / rename workers ---
CONTENT_ANALYSIS_BATCH_SIZE=
MAX_ANALYSIS_FILE_SIZE_MB=
CONTENT_RENAME_BATCH_SIZE=
# full (default): upload whole video to Gemini + clip segmentation; sampled/frames_only: legacy frame sampling
VIDEO_ANALYSIS_MODE=full
VIDEO_FRAME_MAX_WIDTH=768
VIDEO_MAX_SAMPLE_FRAMES=12
# Guardrails for full-video analysis; over-cap videos fall back to sampled
MAX_FULL_VIDEO_ANALYSIS_MB=300
MAX_FULL_VIDEO_DURATION_SEC=900
# Backfill clip segmentation batch size (default 3)
# CLIP_BACKFILL_BATCH_SIZE=3

# HEIC/HEIF ingest (cloud): heic-convert npm first; optional CLI fallbacks:
# HEIF_CONVERT_PATH=/usr/bin/heif-convert
# HEIC_MAGICK_PATH=/usr/bin/magick

# --- Reverse geocoding (Nominatim) ---
NOMINATIM_USER_AGENT=france94-content-manager/0.1 (contact: you@example.com)
NOMINATIM_BASE_URL=
NOMINATIM_ACCEPT_LANGUAGE=
GEOCODE_BATCH_SIZE=25
NOMINATIM_MIN_INTERVAL_MS=1100

# --- Instagram Graph API (review refresh + scheduled publish worker via publish:scheduled / GHA cron) ---
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# INSTAGRAM_GRAPH_API_VERSION=v21.0
# META_APP_ID=
# META_APP_SECRET=
# META_SYSTEM_USER_ID=
# META_BUSINESS_BOOTSTRAP_ACCESS_TOKEN=
# META_SYSTEM_USER_SCOPES=instagram_basic,instagram_content_publish,instagram_manage_insights,pages_read_engagement,pages_show_list

# --- Asset thumbnails (private Supabase Storage; served via /api/content-assets/[id]/thumbnail) ---
ASSET_THUMBNAIL_BUCKET=asset-thumbnails

# --- Public media bucket (Instagram fetches via HTTPS) ---
PUBLIC_MEDIA_BUCKET_NAME=
PUBLIC_MEDIA_BASE_URL=
# PUBLIC_MEDIA_UPLOAD_MAX_ATTEMPTS=5
# PUBLIC_MEDIA_UPLOAD_RETRY_BASE_MS=1500
MAX_PUBLISHING_FILE_SIZE_MB=50
# FORCE_REBUILD_PUBLISHING_JOB=
# FR94_PUBLISHING_LOG=

# --- Review dashboard (Next app) ---
# Auth: Google OAuth via Supabase (see NEXT_PUBLIC_* and ALLOWED_EMAILS above).
# Supabase dashboard: enable Google provider; add http://localhost:3040/auth/callback
# and your production URL to Authentication → URL Configuration → Redirect URLs.

# --- Auto-ingest cron (GitHub Actions) ---
# Toggle, interval, post-type lanes, and threshold are stored in Supabase pipeline_settings.
# GHA polls every 5 min; the worker skips until auto_ingest_interval_minutes has elapsed.
# GH_DISPATCH_TOKEN=  # fine-scoped PAT with actions:write — manual run from review settings
# GH_REPOSITORY=owner/repo
# GH_DISPATCH_REF=main
# CRON_SECRET=  # optional: protect /api/cron/* if added later
