# Google OAuth Web client JSON path (client_id + client_secret). Default: ./f94client.json
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=

# From one-time: npm run oauth:google-drive
GOOGLE_REFRESH_TOKEN=

# Folder to scan (must be visible to the signed-in Google account)
GOOGLE_DRIVE_FOLDER_ID=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
